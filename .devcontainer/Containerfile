# C++ examples devcontainer
# Uses custom base image from ghcr.io/angzarr

ARG CPP_IMAGE=ghcr.io/angzarr-io/angzarr-cpp:latest
FROM ${CPP_IMAGE}

# Install dependencies for cucumber-cpp BDD tests and Mull mutation testing
USER root
RUN apt-get update && apt-get install -y --no-install-recommends \
    libboost-regex-dev \
    libboost-filesystem-dev \
    libboost-system-dev \
    libboost-program-options-dev \
    libboost-thread-dev \
    nlohmann-json3-dev \
    libasio-dev \
    libtclap-dev \
    ruby \
    ruby-dev \
    curl \
    gnupg \
    && rm -rf /var/lib/apt/lists/* \
    && gem install bundler --no-document

# Install Mull mutation testing (LLVM-based, version matches clang)
RUN curl -1sLf 'https://dl.cloudsmith.io/public/mull-project/mull-stable/setup.deb.sh' | bash \
    && CLANG_VER=$(clang --version 2>/dev/null | head -1 | grep -oP '\d+' | head -1 || echo "16") \
    && apt-get update && apt-get install -y --no-install-recommends "mull-${CLANG_VER}" \
    && rm -rf /var/lib/apt/lists/*

# Mark as devcontainer for justfile detection
ENV DEVCONTAINER=true
