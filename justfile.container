# C++ poker examples - container execution
#
# This file runs inside the devcontainer and executes actual build commands.
# It's mounted over justfile when running in a container.

set shell := ["bash", "-c"]

BUILD_DIR := "build"
PROTO_DIR := "angzarr-client-cpp/angzarr/proto"

default:
    @just --list

# Export proto files: core and examples from angzarr-project submodule
proto-gen:
    rm -rf {{PROTO_DIR}}
    mkdir -p $(dirname {{PROTO_DIR}})
    buf export angzarr-project/proto -o _proto_export
    mv _proto_export {{PROTO_DIR}}
    rm -f {{PROTO_DIR}}/examples/ai_sidecar.proto

# Configure and build all C++ components (use gcc for cucumber-cpp compat)
build: proto-gen
    cmake -B {{BUILD_DIR}} -S . -DBUILD_TESTS=ON -DCMAKE_C_COMPILER=gcc -DCMAKE_CXX_COMPILER=g++
    cmake --build {{BUILD_DIR}} -j$(nproc)

# Run unit tests (in-process handlers via cucumber-cpp wire protocol)
test-unit:
    cmake -B {{BUILD_DIR}} -S . -DBUILD_TESTS=ON
    cmake --build {{BUILD_DIR}} -j$(nproc)
    # Install cucumber gems via bundler
    cd features && bundle install --quiet
    # Start the wire server in background (unit_tests binary)
    ./{{BUILD_DIR}}/tests/unit_tests -p 3902 &
    WIRE_PID=$$!; \
    sleep 1; \
    cd features && CUCUMBER_PUBLISH_QUIET=true bundle exec cucumber --require step_definitions --format progress unit/ || { kill $$WIRE_PID 2>/dev/null; exit 1; }; \
    kill $$WIRE_PID 2>/dev/null || true

# Run Gherkin acceptance tests via CommandClient abstraction
# If PLAYER_URL is set, connects to deployed coordinator via gRPC.
# If PLAYER_URL is unset, uses in-process handler calls.
test-acceptance:
    cmake -B {{BUILD_DIR}} -S . -DBUILD_TESTS=ON
    cmake --build {{BUILD_DIR}} -j$(nproc)
    # Install cucumber gems via bundler
    cd features && bundle install --quiet
    # Start the acceptance wire server in background
    PLAYER_URL="${PLAYER_URL:-}" ./{{BUILD_DIR}}/tests/acceptance_runner -p 3903 &
    WIRE_PID=$$!; \
    sleep 1; \
    cd features && CUCUMBER_PUBLISH_QUIET=true bundle exec cucumber --require acceptance/step_definitions --format progress acceptance/ || { kill $$WIRE_PID 2>/dev/null; exit 1; }; \
    kill $$WIRE_PID 2>/dev/null || true

# Run acceptance tests against deployed system (gRPC)
test-acceptance-grpc:
    cmake -B {{BUILD_DIR}} -S . -DBUILD_TESTS=ON
    cmake --build {{BUILD_DIR}} -j$(nproc)
    # Install cucumber gems via bundler
    cd features && bundle install --quiet
    # Start the acceptance wire server with gRPC mode
    PLAYER_URL="${PLAYER_URL:-localhost:1310}" ./{{BUILD_DIR}}/tests/acceptance_runner -p 3903 &
    WIRE_PID=$$!; \
    sleep 1; \
    cd features && CUCUMBER_PUBLISH_QUIET=true bundle exec cucumber --require acceptance/step_definitions --format progress acceptance/ || { kill $$WIRE_PID 2>/dev/null; exit 1; }; \
    kill $$WIRE_PID 2>/dev/null || true

# Run all tests
test: test-unit test-acceptance

# Format code with clang-format
fmt:
    find . -name "*.cpp" -o -name "*.hpp" | grep -v build | xargs clang-format -i

# Lint with clang-tidy (only files known to compile_commands.json)
lint:
    cmake -B {{BUILD_DIR}} -S . -DBUILD_TESTS=ON -DCMAKE_EXPORT_COMPILE_COMMANDS=ON
    grep '"file"' {{BUILD_DIR}}/compile_commands.json \
        | sed 's/.*"file": *"//;s/".*//' \
        | grep -v '/build/' \
        | sort -u \
        | xargs clang-tidy -p {{BUILD_DIR}}

# Clean build artifacts
clean:
    rm -rf {{BUILD_DIR}}

# Run Mull mutation testing on unit test binary
mutation-test:
    #!/usr/bin/env bash
    set -euo pipefail
    MULL_RUNNER=$(command -v mull-runner-17 2>/dev/null || command -v mull-runner 2>/dev/null)
    MULL_FRONTEND=$(find /usr/lib -name "mull-ir-frontend-17" 2>/dev/null | head -1)
    if [ -z "$MULL_RUNNER" ] || [ -z "$MULL_FRONTEND" ]; then
        echo "ERROR: mull not found. Use the angzarr-cpp:latest base image."
        exit 1
    fi
    echo "Running Mull mutation testing (frontend: $MULL_FRONTEND)..."
    cmake -B {{BUILD_DIR}}-mull -S . -DBUILD_TESTS=ON \
        -DCMAKE_CXX_COMPILER="$MULL_FRONTEND" \
        -DCMAKE_CXX_FLAGS="-g -grecord-command-line"
    cmake --build {{BUILD_DIR}}-mull -j$(nproc) --target unit_tests
    $MULL_RUNNER {{BUILD_DIR}}-mull/tests/unit_tests
    echo "Mutation testing complete."

# Auto-format code (clang-format, Google style)
fmt-fix:
    find . -name "*.cpp" -o -name "*.hpp" | grep -v build/ | grep -v angzarr- | xargs clang-format -i --style=Google
